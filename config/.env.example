# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# REACT_APP_API_URL: Base URL of the deployed ingestion/backend (Heroku).
# Point the Control Tower dashboard at your Heroku backend, e.g.:
#   REACT_APP_API_URL="https://kudbee-ingestion-7f3a9c2ad9e.herokuapp.com"
# Leave empty to use same-origin relative paths (default for the monolith deploy).
REACT_APP_API_URL=""

# CORS_ALLOW_ORIGINS: Comma-separated list of origins allowed to call the API.
# Use "*" for open access, or a specific origin like the frontend Heroku URL.
CORS_ALLOW_ORIGINS="*"

# LANGCACHE_API_KEY: Bearer token for Redis LangCache semantic caching.
# Enables semantic deduplication of LLM prompts — if a high-confidence match
# exists, the cached response is returned instantly, saving tokens and latency.
# LANGCACHE_API_KEY="your-api-key-here"

# LANGCACHE_ENDPOINT: Redis LangCache endpoint URL.
# LANGCACHE_ENDPOINT="https://aws-us-east-1.langcache.redis.io/v1/caches/b95111071db14e848cdbe9514138374d"

# PORT: HTTP server port. Required by Heroku (dynamic $PORT binding).
# PORT=3000

# NODE_ENV: Runtime environment. Set to "production" on Heroku.
# NODE_ENV=production

# MONTHLY_BUDGET_USD: Hard cap on cumulative LLM API spend per calendar month.
# Exceeding this returns HTTP 402 until next billing cycle. Default: 50.
# MONTHLY_BUDGET_USD=50

# STREAM_SECRET: HMAC key for SSE stream ticket signing.
# STREAM_SECRET="kudbee-stream-secret"

