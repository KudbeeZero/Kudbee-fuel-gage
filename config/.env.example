# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# REACT_APP_API_URL: Base URL of the deployed ingestion/backend (Heroku).
# Point the Control Tower dashboard at your Heroku backend, e.g.:
#   REACT_APP_API_URL="https://kudbee-ingestion-7f3a9c2ad9e.herokuapp.com"
# Leave empty to use same-origin relative paths (default for the monolith deploy).
REACT_APP_API_URL=""

# CORS_ALLOW_ORIGINS: Comma-separated list of origins allowed to call the API.
# Use "*" for open access, or a specific origin like the frontend Heroku URL.
CORS_ALLOW_ORIGINS="*"

# MONTHLY_BUDGET_USD: Hard cap on cumulative API spend per calendar month.
# All LLM inference calls (Groq, Gemini, etc.) track their cost against this
# budget via Redis accumulator. Once exceeded, all inference requests return
# HTTP 402 Payment Required until the next billing cycle.
# MONTHLY_BUDGET_USD=50

# SINK_TOKEN_BALANCE: Starting token balance for the absorption attenuator.
# When the system pressure rises, sink tokens are minted to buffer load
# without hard circuit breaks. Recycled when the pressure subsides.
# SINK_TOKEN_BALANCE=1000

