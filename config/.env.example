# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# REACT_APP_API_URL: Base URL of the deployed ingestion/backend (Heroku).
# Point the Control Tower dashboard at your Heroku backend, e.g.:
#   REACT_APP_API_URL="https://kudbee-ingestion-7f3a9c2ad9e.herokuapp.com"
# Leave empty to use same-origin relative paths (default for the monolith deploy).
REACT_APP_API_URL=""

# CORS_ALLOW_ORIGINS: Comma-separated list of origins allowed to call the API.
# Use "*" for open access, or a specific origin like the frontend Heroku URL.
CORS_ALLOW_ORIGINS="*"

# STREAM_SECRET: HMAC signing key for SSE stream ticket authentication.
# The /api/auth/stream-ticket endpoint uses this to sign single-use
# tokens. Clients present the ticket as a query parameter on SSE URLs.
# STREAM_SECRET="kudbee-stream-secret"

# -------- DATABASE --------
# DATABASE_URL: Neon Postgres connection string. Required for persistence.
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/kudbee?sslmode=require"

# -------- REDIS --------
# REDIS_URL: Primary Redis for UI telemetry, SSE pub/sub, state.
# REDIS_URL="redis://127.0.0.1:6379"
# REDIS_RATE_LIMIT_URL: Secondary Redis for rate limiting (Heroku addon).
# REDIS_RATE_LIMIT_URL="redis://127.0.0.1:6380"

# -------- RUNTIME --------
# PORT: HTTP server port. Required by Heroku dynamic $PORT binding.
# PORT=3000
# NODE_ENV: Runtime environment. Set to "production" on Heroku.
# NODE_ENV=production

# -------- LLM PROVIDERS --------
# GROQ_API_KEY: API key for Groq LPU inference.
# GROQ_API_KEY="gsk_..."
# GROQ_MODEL: Groq model override (default: llama-3.1-8b-instant)
# VLLM_BASE_URL: vLLM inference server URL.
# VLLM_API_KEY: vLLM API key.

# -------- BUDGET & RATE --------
# MONTHLY_BUDGET_USD: Hard cap on cumulative LLM spend per month (default: 50).
# MONTHLY_BUDGET_USD=50
# SAMPLE_RATE: Statistical sampling rate (default: 1).
# CRUCIBLE_ENABLED: Feature flag for Crucible agent (true/false).
# CRUCIBLE_ENABLED=true

# -------- AGENT AUTH --------
# EDGE_AGENT_PASS: Authentication pass for edge agents.
# SENTINEL_AGENT_PASS: Authentication pass for sentinel agent.
# SENTINEL_MODE: Sentinel operational mode (monitor, enforce, disabled).

# -------- CACHING --------
# LANGCACHE_ENDPOINT: Redis LangCache REST endpoint.
# LANGCACHE_API_KEY: Bearer token for LangCache semantic caching.
# LANGCACHE_API_KEY="lc_..."

