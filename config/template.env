# ===========================================================================
# config/template.env — Kudbee Control Tower environment template
# ---------------------------------------------------------------------------
# Copy this file to `.env` (or set these secrets in your hosting provider's
# Secrets panel) before running the ingestion server or dashboard.
#
# NO REAL SECRETS ARE STORED HERE. Every value is a placeholder; AI Studio and
# CI inject the real values at runtime from the Secrets panel / GitHub Actions
# secrets. Never commit a populated .env.
# ===========================================================================

# --- Core AI provider -------------------------------------------------------
# Gemini API key for telemetry triage / HERMES slow-brain reasoning.
# AI Studio injects this automatically at runtime from the Secrets panel.
GEMINI_API_KEY="REPLACE_WITH_YOUR_GEMINI_API_KEY"

# --- Database (Neon Postgres, system of record) -----------------------------
# Neon connection string. The server degrades to an in-memory store if this is
# unset (Resilient-First), but production requires a real Neon instance.
# Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/kudbee?sslmode=require"

# --- Cache / event-bus (Redis) ----------------------------------------------
# Redis URL used for the telemetry feed, governance ledger, and SSE event bus.
REDIS_URL="redis://default:password@your-redis-host:6379"

# --- App hosting ------------------------------------------------------------
# URL where this applet is hosted (Cloud Run / Heroku). Injected at runtime.
APP_URL="https://your-app-host.example.com"

# Base URL of the deployed ingestion/backend. Leave empty to use same-origin
# relative paths (default for the monolith deploy).
REACT_APP_API_URL=""

# --- Access control ---------------------------------------------------------
# Comma-separated list of allowed CORS origins. Use "*" for open access.
CORS_ALLOW_ORIGINS="*"

# --- GitHub integration (CI / release workflow) -----------------------------
# Token used by scripts/auto-commit.mjs and GitHub Actions to open/merge PRs.
# Scope: repo. Store as a secret — never hardcode.
GITHUB_TOKEN="REPLACE_WITH_YOUR_GITHUB_TOKEN"

# --- Runtime (optional) -----------------------------------------------------
# Port the ingestion server listens on (default 5000).
PORT=5000
# Node environment: development | test | production.
NODE_ENV="production"
