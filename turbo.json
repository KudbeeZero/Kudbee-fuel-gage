{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV", "PORT", "DATABASE_URL", "REDIS_URL", "GEMINI_API_KEY", "STREAM_SECRET", "GROQ_API_KEY"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "typecheck", "lint"],
      "outputs": ["dist/**", "build/**"]
    },
    "typecheck": {
      "dependsOn": [],
      "outputs": []
    },
    "lint": {
      "dependsOn": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["^build"]
    }
  }
}
